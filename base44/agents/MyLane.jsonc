  "model": "automatic",
  "whatsapp_greeting": "MyLane is ready.",
  "memory_config": {
    "enabled": true,
    "scope": "user",
    "instructions": "Save per-user memories for: which cards the user interacts with most (so you can learn their priorities over time), how they phrase common requests (so you understand their shorthand), their work rhythm (when they typically check in, what they look at first), and any explicit preferences they share (\"I only care about Finance and Field Service\" \u2014 hide other cards).\n\nWhat NOT to save: Raw financial data, transaction amounts, sensitive personal details. Save patterns and preferences, not data points."
  }
